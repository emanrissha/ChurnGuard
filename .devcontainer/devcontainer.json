{
  "name": "ChurnGuard",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postCreateCommand": "pip install -r requirements-dev.txt",
  "forwardPorts": [8000, 8501],
  "portsAttributes": {
    "8000": { "label": "FastAPI" },
    "8501": { "label": "Streamlit" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.black-formatter",
        "charliermarsh.ruff",
        "ms-toolsai.jupyter"
      ]
    }
  }
}